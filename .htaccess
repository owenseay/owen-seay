<IfModule mod_headers.c>
    # HTML — short cache, always revalidate
    <FilesMatch "\.(html)$">
        Header set Cache-Control "max-age=300, must-revalidate"
    </FilesMatch>

    # Images — cache longer since they change less
    <FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|ico)$">
        Header set Cache-Control "max-age=3600"
    </FilesMatch>

    # CSS/JS — short cache
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "max-age=300, must-revalidate"
    </FilesMatch>
</IfModule>
